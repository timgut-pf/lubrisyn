{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,

  "name": "acf/example-block",
  "title": "Example Block",
  "description": "Example ACF block showing all common block.json options.",
  "category": "layout",
  "icon": "megaphone",
  "keywords": ["example", "acf", "lubrisyn"],
  "version": "1.0.0",
  "textdomain": "lubrisyn",

  "acf": {
    "mode": "preview",
    "renderTemplate": "block.php",
    "blockVersion": 2,
    "postTypes": ["post", "page"],
    "validate": true,
    "usePostMeta": false
  },

  "style": ["file:./block.css"],
  "editorStyle": ["file:./editor.css"],
  "script": ["file:./block.js"],
  "viewScript": ["file:./view.js"],
  "editorScript": ["file:./editor.js"],

  "supports": {
    "align": ["wide", "full"],
    "anchor": true,
    "className": true,
    "customClassName": true,
    "html": false,
    "inserter": true,
    "multiple": true,
    "reusable": true,
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    }
  },

  "example": {
    "attributes": {}
  },

  "parent": null,
  "ancestor": null,
  "allowedBlocks": null
}
